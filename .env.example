# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=agentic-data-cleaning

# Models
PRIMARY_MODEL=gpt-4o
FAST_MODEL=gpt-4o-mini

# Thresholds
CONFIDENCE_THRESHOLD=0.7
MAX_CLEANING_ITERATIONS=3
CHUNK_SIZE=50000
POLARS_THRESHOLD=500000

# Database (production)
DATABASE_URL=sqlite:///./data/agentic_clean.db

# Redis (production checkpointing)
# REDIS_URL=redis://localhost:6379/0
